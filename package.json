{
  "name": "leadey-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/migrate.ts && tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/migrate.js && node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-s3": "^3.1078.0",
    "@aws-sdk/s3-request-presigner": "^3.1078.0",
    "@clerk/express": "^2.0.1",
    "@types/multer": "^2.1.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.0",
    "express": "^4.21.2",
    "http-errors": "^2.0.0",
    "imapflow": "^1.4.0",
    "mailparser": "^3.9.9",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "openai": "^6.42.0",
    "postgres": "^3.4.5",
    "resend": "^6.12.3",
    "stripe": "^21.0.1",
    "svix": "^1.84.1",
    "twilio": "^5.12.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/http-errors": "^2.0.4",
    "@types/mailparser": "^3.4.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.0",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
